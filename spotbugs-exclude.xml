<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        Exclude EI_EXPOSE_REP2 on Java Records.
        Record canonical constructors store parameters directly, but records
        are designed to be transparent data carriers. This is a known SpotBugs
        false positive for records.
    -->
    <Match>
        <Package name="com.agentmemorystore.application.dto"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Exclude EI_EXPOSE_REP2 for injected Spring beans in controllers, usecases, and batch configs -->
    <Match>
        <Or>
            <Package name="com.agentmemorystore.presentation.controller"/>
            <Package name="com.agentmemorystore.application.usecase"/>
            <Package name="com.agentmemorystore.application.batch"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP for MemoryStats record -->
    <Match>
        <Class name="com.agentmemorystore.domain.model.MemoryStats"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
